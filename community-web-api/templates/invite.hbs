<!doctype html>
<html lang="en">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Community Invite</title>
</head>

<body style="margin: 0; padding: 0; background-color: #f5f5f5; font-family: Arial, sans-serif; color: #1f2937;">
	<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding: 24px 0;">
		<tr>
			<td align="center">
				<table role="presentation" width="600" cellspacing="0" cellpadding="0"
					style="max-width: 600px; background-color: #ffffff; border-radius: 8px; overflow: hidden;">
					<tr>
						<td style="padding: 24px;">
							<h1 style="margin: 0 0 16px 0; font-size: 24px; line-height: 1.3;">
								You are invited to join Community
							</h1>

							<p style="margin: 0 0 12px 0; font-size: 16px; line-height: 1.6;">Hi {{name}},</p>

							<p style="margin: 0 0 16px 0; font-size: 16px; line-height: 1.6;">
								{{adminName}} has invited you to join the Community platform.
							</p>

							<p style="margin: 0 0 20px 0; font-size: 16px; line-height: 1.6;">
								Use the <a href="{{portalUrl}}/members/sign-up?token={{token}}&email={{email}}"
									style="color: #2563eb; text-decoration: none;">link to
									accept invitation</a>
							</p>

							<p style="margin: 0; font-size: 14px; color: #6b7280; line-height: 1.6;">
								If you did not expect this invitation, you can ignore this email.
							</p>
						</td>
					</tr>
				</table>
			</td>
		</tr>
	</table>
</body>

</html>