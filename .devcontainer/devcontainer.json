// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
	"features": {
		"ghcr.io/devcontainers-extra/features/nestjs-cli:2": {}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [3000],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "yarn install",

	// Configure tool-specific properties.
	"customizations": {
    // Configure VS Code specific settings and extensions
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        // Additional settings, e.g., for ESLint or Prettier
        "eslint.alwaysShowStatus": true,
        "prettier.enable": true
      },
      "extensions": [
		"github.copilot",
		"github.copilot-chat",
        // Recommended extensions for Node.js/TypeScript development
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
		// Mermaid extension for diagram support 
		"mermaidchart.vscode-mermaid-chart",
		// REST Client extension for API testing
		"humao.rest-client"
      ]
    }
  },

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	 "remoteUser": "node",
	 "runArgs": [ "--network=develop-network" ]
}
